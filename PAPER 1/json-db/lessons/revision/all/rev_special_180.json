    { "q": "63. ஒரு முக்கோணத்தின் மூன்று கோணங்களின் கூடுதல் என்ன?", "options": ["90°", "360°", "180°", "270°"], "a": 2, "ex": "சமதள முக்கோணத்தின் மூன்று கோணங்களின் கூட்டுத்தொகை எப்போதும் 180° இருக்கும்." },
    { "q": "73. 1 கி.மீ என்பது எத்தனை மீட்டர்களுக்குச் சமம்?", "options": ["100 மீ", "500 மீ", "10,000 மீ", "1000 மீ"], "a": 3, "ex": "மெட்ரிக் முறையில் 1 கிலோமீட்டர் = 1000 மீட்டர்கள்." },
    { "q": "85. ஒரு வட்டத்தின் மிகப்பெரிய நாண் எது?", "options": ["ஆரம்", "வில்", "விகிதம்", "விட்டம்"], "a": 3, "ex": "மையப் புள்ளி வழியாகச் செல்லும் விட்டம் (Diameter) தான் வட்டத்தின் மிகப்பெரிய நாண் ஆகும்." },
    { "q": "91. மனித உடலில் உள்ள எலும்புகளின் எண்ணிக்கை எவ்வளவு?", "options": ["300", "206", "150", "250"], "a": 1, "ex": "குழந்தைகளுக்கு அதிகமாக இருந்தாலும், முதிர்ச்சியடைந்த மனித உடலில் 206 எலும்புகள் உள்ளன." },
    { "q": "93. செல்லின் ஆற்றல் மையம் (Powerhouse of the Cell) எது?", "options": ["மைட்டோகாண்ட்ரியா", "உட்கரு", "ரைபோசோம்", "லைசோசோம்"], "a": 0, "ex": "மைட்டோகாண்ட்ரியா செரிமானத்தின் மூலம் ஆற்றலை உருவாக்கி வழங்குகிறது." },
    { "q": "96. திரவ நிலையில் உள்ள ஒரே உலோகம் எது?", "options": ["தங்கம்", "வெள்ளி", "பாதரசம்", "இரும்பு"], "a": 2, "ex": "பாதரசம் (Mercury) மட்டுமே அறை வெப்பநிலையில் திரவமாக இருக்கும் உலோகம்." },
    { "q": "104. செல்லின் 'மூளை' எனக் கருதப்படுவது எது?", "options": ["சைட்டோபிளாசம்", "உட்கரு", "செல் சுவர்", "ரைபோசோம்"], "a": 1, "ex": "உட்கரு (Nucleus) செல்லின் அனைத்து செயல்பாடுகளையும் கட்டுப்படுத்துகிறது." },
    { "q": "121. இந்திய அரசியலமைப்புச் சட்டம் நடைமுறைக்கு வந்த ஆண்டு?", "options": ["1947", "1950", "1952", "1948"], "a": 1, "ex": "1949-ல் ஏற்கப்பட்டு, 1950 ஜனவரி 26 முதல் நடைமுறைக்கு வந்தது." },
    { "q": "125. சூரியக் குடும்பத்திலேயே மிகப்பெரிய கோள் எது?", "options": ["வியாழன்", "சனி", "பூமி", "நெப்டியூன்"], "a": 0, "ex": "வியாழன் (Jupiter) சூரியக் குடும்பத்தின் மிகப்பெரிய கோள் ஆகும்." },
    { "q": "133. இந்தியாவின் முதல் குடிமகன் யார்?", "options": ["பிரதமர்", "குடியரசுத் தலைவர்", "ஆளுநர்", "முதலமைச்சர்"], "a": 1, "ex": "அரசியலமைப்புச் சட்டத்தின்படி குடியரசுத் தலைவரே நாட்டின் முதல் குடிமகன் ஆவார்." },
    { "q": "151. உளவியலின் தந்தை (Father of Psychology) என அழைக்கப்படுபவர்?", "options": ["சிக்மண்ட் பிராய்டு", "வில்ஹெல்ம் வுண்ட்", "வாட்சன்", "ஸ்கின்னர்"], "a": 1, "ex": "1879-ல் முதல் உளவியல் ஆய்வகத்தை நிறுவிய வில்ஹெல்ம் வுண்ட் உளவியலின் தந்தை எனப்படுகிறார்." },
    { "q": "157. ஒரு குழந்தையின் வயது 10, மன வயது 12 எனில் அவனது நுண்ணறிவு ஈவு (IQ)?", "options": ["100", "120", "80", "150"], "a": 1, "ex": "IQ = (Mental Age / Chronological Age) * 100 = (12/10) * 100 = 120." },
