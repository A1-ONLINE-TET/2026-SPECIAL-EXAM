        { "q": "விலங்குகளுக்கு மருத்துவமனை கட்டிய முதல் அரசர் யார்?", "options": ["அசோகர்", "பிந்துசாரர்", "கனிஷ்கர்", "அக்பர்"], "a": 0 },
        { "q": "வரலாற்றுக்கு முந்தைய காலத்தைப் பற்றி அறிய உதவுவது எது?", "options": ["கல்வெட்டுகள்", "நாணயங்கள்", "தொல்பொருள் சான்றுகள்", "இலக்கியங்கள்"], "a": 2 },
        { "q": "அசோகர் எந்த மதத்தைப் பின்பற்றினார்?", "options": ["சைவம்", "வைணவம்", "புத்த மதம்", "சமண மதம்"], "a": 2 },
        { "q": "கலிங்கப் போர் அசோகருக்கு எதை ஏற்படுத்தியது?", "options": ["மகிழ்ச்சி", "மனமாற்றம்", "ஆணவம்", "துக்கம்"], "a": 1 },
        { "q": "தேசியக் கொடியின் மையத்தில் உள்ள சக்கரம் எந்த நிறத்தில் உள்ளது?", "options": ["கருப்பு", "பச்சை", "கருநீலம்", "சிவப்பு"], "a": 2 },
        { "q": "மனிதர்கள் வேட்டைக்குச் செல்லும்போது பாதுகாப்பிற்காக எதை அழைத்துச் சென்றனர்?", "options": ["பசு", "நாய்", "ஆடு", "கோழி"], "a": 1 },
        { "q": "அசோகர் ஒரு ______ அரசர்.", "options": ["கொடிய", "வீரமான மற்றும் அமைதியான", "பலவீனமான", "அறியப்படாத"], "a": 1 },
        { "q": "தொடக்க கால மனிதன் எங்கு வாழ்ந்தான்?", "options": ["வீடு", "நகரம்", "குகை", "அரண்மனை"], "a": 2 },
        { "q": "வரலாற்றுக்கும் முந்தைய காலத்திற்கும் இடைப்பட்ட காலம் ______.", "options": ["நவீன காலம்", "தொடக்க கால வரலாறு", "இடைக்காலம்", "வருங்காலம்"], "a": 1 },
        { "q": "சார்லஸ் ஆலன் எழுதிய நூல் எது?", "options": ["இந்தியா", "Search for the India's Lost Emperor", "வரலாறு", "அசோகர் கதை"], "a": 1 },
        { "q": "எந்த அரசர் காலத்தைச் சேர்ந்த கல்வெட்டுகள் மிக அதிகம்?", "options": ["அசோகர்", "சேரன் செங்குட்டுவன்", "கரிகாலன்", "ஹர்ஷர்"], "a": 0 },
        { "q": "முற்கால மனிதர்கள் வேட்டையாடுவதை எதில் பதிவு செய்தனர்?", "options": ["புத்தகம்", "பாறை ஓவியங்கள்", "துணி", "ஓலைச்சுவடி"], "a": 1 },
        { "q": "அசோகர் தர்மத்தைப் பரப்ப எதை உருவாக்கினார்?", "options": ["கோவில்கள்", "தர்ம சக்கரங்கள் மற்றும் தூண்கள்", "சிறைச்சாலை", "பள்ளிகள்"], "a": 1 },
        { "q": "அசோகரை வரலாற்றுப் பக்கங்களுக்குக் கொண்டு வந்த ஆங்கிலேயர் யார்?", "options": ["ஜேம்ஸ் பிரின்செப்", "மெக்காலே", "டயர்மான்", "கர்சன்"], "a": 0 },
        { "q": "சாரநாத் அசோகர் தூண் எங்கு உள்ளது?", "options": ["தமிழ்நாடு", "உத்தரப் பிரதேசம்", "கேரளா", "மத்தியப் பிரதேசம்"], "a": 1 },
        { "q": "கல்வெட்டுகள் ஒரு ______ சான்று.", "options": ["இலக்கியச்", "தொல்லியல்", "வாய்மொழி", "கற்பனை"], "a": 1 },
        { "q": "பழைய கற்கால மனிதன் பயன்படுத்திய ஆயுதம்?", "options": ["கோடரி (கல்)", "துப்பாக்கி", "வாள் (இரும்பு)", "வில்"], "a": 0 },
        { "q": "வரலாற்றின் மூலம் நாம் எதை அறிந்துகொள்கிறோம்?", "options": ["வருங்காலம்", "கடந்த கால வாழ்க்கை முறை", "விண்வெளி", "கதை"], "a": 1 }
    ]
