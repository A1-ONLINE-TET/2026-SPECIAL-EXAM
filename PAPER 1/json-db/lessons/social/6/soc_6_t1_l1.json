        { "q": "இஸ்டோரியா என்பதன் பொருள் என்ன?", "options": ["விசாரிப்பதன் மூலம் கற்றல்", "பாடமாகப் படித்தல்", "கதைகளைக் கூறுதல்", "நினைவில் கொள்ளுதல்"], "a": 0 },
        { "q": "வரலாற்றின் தந்தை என்று அழைக்கப்படுபவர் யார்?", "options": ["சாணக்கியர்", "ஹெரோடோட்டஸ்", "அரிஸ்டாட்டில்", "அலெக்சாண்டர்"], "a": 1 },
        { "q": "பழங்கால மனிதன் வேட்டையாடப் பயன்படுத்திய கருவிகள் எதனால் ஆனவை?", "options": ["இரும்பு", "தங்கம்", "கல்", "செம்பு"], "a": 2 },
        { "q": "மனிதன் வேட்டையாடுவதற்காகப் பழக்கிய முதல் விலங்கு எது?", "options": ["பூனை", "குதிரை", "யானை", "நாய்"], "a": 3 },
        { "q": "பாறை ஓவியங்கள் எங்கு வரையப்பட்டுள்ளன?", "options": ["கோவில்களில்", "குகைச் சுவர்களில்", "வீடுகளில்", "மின்கம்பங்களில்"], "a": 1 },
        { "q": "வெற்றிக்குப் பின் போரைத் துறந்த முதல் அரசர் யார்?", "options": ["அக்பர்", "அசோகர்", "சந்திரகுப்தர்", "ராஜராஜ சோழன்"], "a": 1 },
        { "q": "சாரநாத் தூணிலுள்ள சக்கரத்தில் எத்தனை ஆரக் கால்கள் உள்ளன?", "options": ["12", "24", "36", "48"], "a": 1 },
        { "q": "கல்வெட்டுகளைப் பற்றி ஆராயும் துறை எது?", "options": ["நாணயவியல்", "கல்வெட்டியல்", "வானியல்", "புவியியல்"], "a": 1 },
        { "q": "நாணயவியல் என்பது எதைப் பற்றிய படிப்பு?", "options": ["கல்வெட்டுகள்", "கதைகள்", "நாணயங்கள்", "கற்கருவிகள்"], "a": 2 },
