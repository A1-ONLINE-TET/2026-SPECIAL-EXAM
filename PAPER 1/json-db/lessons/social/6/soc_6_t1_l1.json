{
    "lesson_meta": {
        "title": "வரலாறு என்றால் என்ன?",
        "subject": "சமூக அறிவியல்",
        "term": "பருவம் 1",
        "lesson_no": "பாடம் 1"
    },
    "material": {
        "sections": [
            {
                "section_title": "1. அடிப்படை அறிமுகம்",
                "items": [
                    { "q": "வரலாறு என்பது எதன் காலவரிசைப் பதிவு?", "a": "[[கடந்த கால நிகழ்வுகளின்]] காலவரிசைப் பதிவு." },
                    { "q": "History என்ற சொல் எம்மொழிச் சொல்லிலிருந்து உருவானது?", "a": "[[இஸ்டோரியா (Istoria)]] என்ற கிரேக்கச் சொல்." },
                    { "q": "இஸ்டோரியா என்பதன் பொருள் என்ன?", "a": "[[விசாரிப்பதன் மூலம் கற்றல்]]." },
                    { "q": "வரலாற்றின் தந்தை என்று அழைக்கப்படுபவர் யார்?", "a": "[[ஹெரோடோட்டஸ்]]." }
                ]
            },
            {
                "section_title": "2. வரலாற்றுக் காலங்கள்",
                "items": [
                    { "q": "வரலாற்றுக்கு முந்தைய காலம் என்பது எது?", "a": "[[கற்கருவிகளைப் பயன்படுத்தியதற்கும்]] மற்றும் [[எழுத்து முறைகளை]] உருவாக்கியதற்கும் இடைப்பட்ட காலம்." },
                    { "q": "வரலாற்றுத் தொடக்க காலம் (Proto-history) என்றால் என்ன?", "a": "வரலாற்றுக்கும் வரலாற்றுக்கு முந்தைய காலத்திற்கும் இடைப்பட்ட காலம்; இங்கு [[எழுத்து பூர்வமான ஆதாரங்கள்]] இருந்தும் அவற்றை இன்னும் வாசிக்க முடியவில்லை." },
                    { "q": "தொல்பொருட்களின் வயதைக் கணிக்கப் பயன்படும் முறை எது?", "a": "[[கார்பன் 14]] முறை (கதிரியக்கக் கார்பன் ஆய்வு)." }
                ]
            },
            {
                "section_title": "3. பேரரசர் அசோகர்",
                "items": [
                    { "q": "வெற்றிக்குப் பின் போரைத் துறந்த முதல் அரசர் யார்?", "a": "[[அசோகர்]]." },
                    { "q": "விலங்குகளுக்குத் தனியே மருத்துவமனை கட்டிய முதல் அரசர் யார்?", "a": "[[அசோகர்]]." },
                    { "q": "அசோகர் எந்தப் போருக்குப் பின் புத்த மதத்தைத் தழுவினார்?", "a": "[[கலிங்கப் போர்]]." },
                    { "q": "நமது தேசியக் கொடியில் உள்ள 24 ஆரக் கால் சக்கரம் எங்கிருந்து எடுக்கப்பட்டது?", "a": "சாரநாத் [[அசோகர் தூணிலிருந்து]] எடுக்கப்பட்டது." },
                    { "q": "அசோகரின் வரலாற்றை உலகுக்கு வெளிக்கொண்டு வந்த ஆங்கிலேயர்கள் யார்?", "a": "[[வில்லியம் ஜோன்ஸ்]], [[ஜேம்ஸ் பிரின்செப்]], [[அலெக்சாண்டர் கன்னிங்ஹாம்]]." }
                ]
            },
            {
                "section_title": "4. வரலாற்று ஆதாரங்கள்",
                "items": [
                    { "q": "நாணயங்களைப் பற்றி ஆய்வு செய்யும் துறை எது?", "a": "[[நாணயவியல்]] (Numismatics)." },
                    { "q": "கல்வெட்டுகளை ஆராயும் துறை எது?", "a": "[[கல்வெட்டியல்]] (Epigraphy)." },
                    { "q": "மனிதன் முதன்முதலில் பழக்கிய விலங்கு எது?", "a": "[[நாய்]] (பாதுகாப்பு மற்றும் வேட்டைக்காக)." },
                    { "q": "பண்டைய மனிதர்கள் குகைப் பாறைகளில் எதற்காக ஓவியம் வரைந்தனர்?", "a": "[[வேட்டைக்குச் செல்ல முடியாதவர்களுக்கு]] வேட்டை நிகழ்வுகளைத் தெரியப்படுத்தவும் மற்றும் [[பொழுதுபோக்கிற்காகவும்]]." }
                ]
            }
        ]
    },
