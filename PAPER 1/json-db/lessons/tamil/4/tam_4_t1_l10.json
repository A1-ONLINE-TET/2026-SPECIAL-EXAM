  "material": {
    "sections": [
      {
        "title": "அகரமுதலி (பொருள் அறிவோம்)",
        "type": "infobox",
        "content": [
          {
            "text": "<strong>அண்டை நாடு:</strong> பக்கத்து நாடு"
          },
          {
            "text": "<strong>அண்ணல்:</strong> கருணை உடையவர்"
          },
          {
            "text": "<strong>ஆசி:</strong> வாழ்த்து"
          },
          {
            "text": "<strong>ஆட்டாந்தொழு:</strong> ஆடு கட்டும் இடம்"
          },
          {
            "text": "<strong>ஆல்:</strong> ஆலமரம்"
          },
          {
            "text": "<strong>ஆவி:</strong> உயிர்"
          },
          {
            "text": "<strong>இலகுவான:</strong> எளிமையான"
          },
          {
            "text": "<strong>ஓலைக்கொட்டான்:</strong> ஓலையால் முடையப்பட்ட சிறு கூடை"
          },
          {
            "text": "<strong>கனிந்து:</strong> பழுத்து"
          },
          {
            "text": "<strong>சூழ்ச்சி:</strong> தந்திரம்"
          },
          {
            "text": "<strong>தையலர்:</strong> பெண்கள்"
          },
          {
            "text": "<strong>தொலைவு:</strong> தூரம்"
          },
          {
            "text": "<strong>மன்னர்:</strong> அரசர்"
          },
          {
            "text": "<strong>வல்லமை:</strong> வலிமை"
          },
          {
            "text": "<strong>வியப்பு:</strong> ஆச்சரியம்"
          }
        ]
      }
    ]
  },
