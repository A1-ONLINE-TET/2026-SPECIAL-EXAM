        { "q": "ய, ர, ல, வ, ழ, ள ஆகிய எழுத்துக்கள் ______ மெய்கள்.", "options": ["வல்லினம்", "மெல்லினம்", "இடையினம்", "உயிர்"], "a": 2, "ex": "இவை இடையின மெய்கள்." },
        { "q": "மொழிக்கு முதலில் வரும் உயிர்மெய் எழுத்து வரிசைகளில் சேராதது எது?", "options": ["க", "ச", "த", "ட"], "a": 3, "ex": "ட, ண, ர, ல, ழ, ள, ற, ன ஆகியவை மொழி முதலில் வராது." },
        { "q": "மொழி இறுதியில் வராத உயிரெழுத்து எது? (அளபெடை தவிர)", "options": ["அ", "இ", "உ", "ஒன்றுமில்லை"], "a": 3, "ex": "பன்னிரண்டு உயிரெழுத்துக்களும் மெய்யுடன் இணைந்து உயிர்மெய்யாக மொழி இறுதியில் வரும்." },
        { "q": "மெய்யெழுத்துக்கள் எதன் உதவியோடு ஒலிக்கும்?", "options": ["உயிரின் உதவி", "வாயின் உதவி", "மூக்கின் உதவி", "உடல் இயக்கத்தின் உதவி"], "a": 3, "ex": "மெய்யெழுத்துக்கள் பிறக்க உடல் இயக்கம் அவசியம்." },
        { "q": "முதலெழுத்துக்களைச் சார்ந்து வரும் எழுத்துக்கள் ______ எனப்படும்.", "options": ["முதலெழுத்து", "சார்பெழுத்து", "உயிர்மெய்", "ஆய்தம்"], "a": 1, "ex": "முதலெழுத்துக்களைச் சார்ந்து பிறப்பதால் இவை சார்பெழுத்துக்கள்." },
        { "q": "மாத்திரை கணக்கிடுக: 'தமிழ்' (Ta-mi-zh)", "options": ["2 1/2", "3", "3 1/2", "2"], "a": 0, "ex": "த(1) + மி(1) + ழ்(1/2) = 2.5." },
        { "q": "மாத்திரை கணக்கிடுக: 'ஆற்றல்' (Aa-tr-tral)", "options": ["3", "3 1/2", "4", "4 1/2"], "a": 1, "ex": "ஆ(2) + ற்(1/2) + ற(1) + ல்(1/2) = 4 [திருத்தம்: ஆ(2)+ற்(0.5)+ற(1)+ல்(0.5) = 4.0. ஆ(2), ற்(0.5), ற(1), ல்(0.5) சேர்த்தால் 4. கவனி: ற்(0.5), ல்(0.5) = 1.0. 2+1+1 = 4.0] (ஆக்சுவலி 3.5 அல்ல 4).", "options": ["3", "4", "3 1/2", "4 1/2"], "a": 1 },
        { "q": "கீழ்க்கண்டவற்றுள் எது மெல்லின மெய்?", "options": ["ச்", "ண்", "வ்", "ற்"], "a": 1, "ex": "ண் - ஙஞணநமன." },
        { "q": "சார்பெழுத்து வகைகளில் இல்லாதது எது?", "options": ["உயிர்மெய்", "ஆய்தம்", "உயிரளபெடை", "மெய்யெழுத்து"], "a": 3, "ex": "மெய்யெழுத்து ஒரு முதலெழுத்து." },
        { "q": "உயிர்மெய் எழுத்தின் கால அளவு எதைப் பொறுத்து அமையும்?", "options": ["மெய்யெழுத்தை", "உயிரெழுத்தை", "ஆய்தத்தை", "எதுவுமில்லை"], "a": 1, "ex": "உயிர்மெய்யின் கால அளவு சேரும் உயிரெழுத்தைப் பொறுத்தது." },
        { "q": "மொழி இறுதியில் வரும் மெய்களில் அல்லாதது எது?", "options": ["ஞ்", "ம்", "ன்", "க்"], "a": 3, "ex": "வல்லின மெய்கள் க், ச், ட், த், ப், ற் மொழி இறுதியில் வராது." },
        { "q": "கு, சு, டு, து, பு, று - இவை எவ்வகை எழுத்துக்கள்?", "options": ["முதலெழுத்து", "சார்பெழுத்து (குற்றியலுகரம்)", "உயிரெழுத்து", "மெய்யெழுத்து"], "a": 1, "ex": "இவை சார்பெழுத்து வகையைச் சேர்ந்த குற்றியலுகரம்." },
        { "q": "ஐ, ஔ - இவற்றுக்கு எத்தனை மாத்திரை?", "options": ["1", "2", "1/2", "3"], "a": 1, "ex": "ஐ, ஔ என்பவை உயிர்நெடில் என்பதால் 2 மாத்திரை." },
        { "q": "தன்முன் ஒரு குறிலையும் பின் ஒரு வல்லின உயிர்மெய்யையும் பெற்று வரும் எழுத்து?", "options": ["உயிர்மெய்", "ஆய்தம்", "உயிரளபெடை", "குற்றியலுகரம்"], "a": 1, "ex": "ஆய்த எழுத்து இடையில் வரும்போது இம்முறையைப் பின்பற்றும் (எ.கா: அஃது)." },
        { "q": "உயிர்மையும் ஆய்தமும் எவ்வகை எழுத்துக்கள்?", "options": ["முதல்", "சார்பு", "உயிர்", "மெய்"], "a": 1, "ex": "இவை சார்பெழுத்துக்கள்." },
        { "q": "மொழிக்கு முதலில் வரும் 'ஞ' வரிசை எழுத்துக்கள் எத்தனை?", "options": ["1", "4", "8", "12"], "a": 1, "ex": "ஞ, ஞா, ஞெ, ஞொ ஆகிய நான்கு எழுத்துக்களும் மொழி முதலில் வரும்." },
        { "q": "மொழிக்கு முதலில் வரும் 'ந' வரிசை எழுத்துக்கள் எத்தனை?", "options": ["1", "8", "10", "12"], "a": 1, "ex": "ந வரிசையில் 8 எழுத்துக்கள் வரும்." },
        { "q": "கூற்று: மொழி இறுதியில் உயிரெழுத்துக்கள் தனித்து வருவதில்லை. காரணம்: அளபெடையில் மட்டுமே உயிரெழுத்துக்கள் மொழி இறுதியில் வரும்.", "options": ["கூற்று சரி, காரணம் சரி", "கூற்று சரி, காரணம் தவறு", "கூற்று தவறு, காரணம் சரி", "இரண்டும் தவறு"], "a": 0, "ex": "உயிரெழுத்துக்கள் மெய்யுடன் இணைந்தே மொழி இறுதியில் வரும், தனித்து வராது." },
        { "q": "மொழி இறுதியில் வராத மெய்கள் எத்தனை?", "options": ["7", "11", "18", "12"], "a": 0, "ex": "வல்லினம் 6 + ங் (மெல்லின வரிசையில் ஒன்று) = 7 மெய்கள் மொழி இறுதியில் வராது." },
        { "q": "பொருத்துக: 1. முப்புள்ளி - அ. தனிநிலை, 2. அ - ஆ. உயிர்க்குறில், 3. ஈ - இ. உயிர்நெடில்", "options": ["1-அ, 2-ஆ, 3-இ", "1-ஆ, 2-அ, 3-இ", "1-இ, 2-ஆ, 3-அ", "1-அ, 2-இ, 3-ஆ"], "a": 0 },
        { "q": "தமிழ் மொழியின் முதல் எழுத்து வரிசை எங்கு தொடங்குகிறது?", "options": ["அ", "க", "ஃ", "ன்"], "a": 0, "ex": "அ முதல் ஔ வரை உயிர் 12." },
        { "q": "ஒரு சொல்லின் முதலில் வரக்கூடிய எழுத்து எது?", "options": ["ற்", "ழ்", "பா", "ண்"], "a": 2, "ex": "பா (ப வரிசை) மொழி முதலில் வரும்." },
        { "q": "செய்யுளில் இசை குறையும்போது அதனை நிறைவு செய்ய வரும் சார்பெழுத்து?", "options": ["உயிர்மையும்", "ஆய்தம்", "உயிரளபெடை", "ஒற்றளபெடை"], "a": 2, "ex": "உயிரளபெடை இசை நிறைவு செய்ய வரும்." },
        { "q": "புள்ளி வைத்த மா எழுத்து (ம்) எவ்வாறு அழைக்கப்படும்?", "options": ["உயிர்", "மெய்", "உயிர்மெய்", "ஆய்தம்"], "a": 1, "ex": "மெய்யெழுத்து." },
        { "q": "தமிழ் எழுத்துக்களில் மார்பிலிருந்து பிறக்கும் மெய்கள்?", "options": ["வல்லினம்", "மெல்லினம்", "இடையினம்", "ஆய்தம்"], "a": 0, "ex": "வல்லினம் மார்பிலிருந்து பிறக்கும்." },
        { "q": "மூக்கிலிருந்து பிறக்கும் மெய்கள் எவை?", "options": ["வல்லினம்", "மெல்லினம்", "இடையினம்", "ஆய்தம்"], "a": 1, "ex": "மெல்லினம் மூக்கிலிருந்து பிறக்கும்." },
        { "q": "கழுத்திலிருந்து பிறக்கும் மெய்கள் எவை?", "options": ["இடையினம்", "வல்லினம்", "மெல்லினம்", "எதுவுமில்லை"], "a": 0, "ex": "இடையினம் கழுத்திலிருந்து பிறக்கும்." },
        { "q": "உயிருக்கு முதன்மையானது காற்று. அதுபோல மொழிக்கு முதன்மையானது?", "options": ["எழுத்து", "சொல்", "பொருள்", "இலக்கணம்"], "a": 0, "ex": "எழுத்துகளே மொழியின் அடிப்படை." },
        { "q": "கீழ்க்கண்டவற்றுள் எது உயிர்மெய் நெடில்?", "options": ["கி", "சு", "தே", "மொ"], "a": 2, "ex": "த் + ஏ = தே (உயிர்மெய் நெடில்)." },
        { "q": "மொழி இறுதியில் வரும் குற்றியலுகர எழுத்துக்கள் எத்தனை?", "options": ["1", "6", "12", "18"], "a": 1, "ex": "கு, சு, டு, து, பு, று ஆகிய 6 எழுத்துக்களும் மொழி இறுதியில் வரலாம்." },
        { "q": "முதலெழுத்துக்கள் 30. சார்பெழுத்துக்கள் 10. இரண்டும் சேராத எழுத்து உண்டா?", "options": ["உண்டு", "இல்லை", "கூற முடியாது", "ஆய்தம்"], "a": 1, "ex": "தமிழ் எழுத்துக்கள் அனைத்தும் ஏதேனும் ஒரு வகைக்குள் அடங்கிவிடும்." },
        { "q": "சொல்லின் முதலில் வரும் 'வ' வரிசை எழுத்துக்கள் எத்தனை?", "options": ["1", "8", "6", "12"], "a": 1, "ex": "வ, வா, வி, வீ, வெ, வே, வை, வௌ ஆகிய 8 எழுத்துக்கள் வரும்." },
        { "q": "சார்பெழுத்து வகைகளில் 'அளபெடை' எத்தனை வகைப்படும்?", "options": ["1", "2", "3", "4"], "a": 1, "ex": "உயிரளபெடை, ஒற்றளபெடை என 2 வகைப்படும்." },
        { "q": "தமிழ் எழுத்துக்களில் ஆய்த எழுத்து மட்டுமே ______ ஒலிக்கும்.", "options": ["நேராக", "மென்மையாக", "தனித்து", "வல்லினமாக"], "a": 2, "ex": "ஆய்தம் தனித்து வரும் இயல்புடையது (தனிநிலை)." },
        { "q": "உனது நண்பன் 'அஃது' என்று எழுதினான். இதில் ஆய்த எழுத்து சொல்லின் எங்கு வந்துள்ளது?", "options": ["முதலில்", "இறுதியில்", "இடையில்", "முதலும் இறுதியும்"], "a": 2, "ex": "ஆய்த எழுத்து சொல்லின் இடையில் மட்டுமே வரும்." }
    ]
}
